# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/oops?retryWrites=true&w=majority

# JWT
JWT_ACCESS_SECRET=change-me-64-chars-random
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-64-chars-random
JWT_REFRESH_EXPIRES_IN=7d
JWT_TEMP_SECRET=change-me-64-chars-random
JWT_TEMP_EXPIRES_IN=10m

# CORS
ADMIN_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5174

# Gmail OAuth2 (system emails: OTP, password reset)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_FROM=noreply@oopsfashion.com

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=oops

# Uploads
MAX_FILE_SIZE=5242880
